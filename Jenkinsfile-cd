pipeline {
    agent any

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Image tag to deploy')
    }

    environment {
        IMAGE_NAME = "sivadhanush24/spring-ci-cd"
        KUBECTL    = "/opt/homebrew/bin/kubectl"
        KUBECONFIG = "/Users/dhanush/.kube/config"
        NAMESPACE = "reactive-app"
    }

    stages {

        stage('Verify Cluster') {
            steps {
                sh '${KUBECTL} cluster-info'
                sh '${KUBECTL} get nodes'
            }
        }

        stage('Create Namespace') {
            steps {
                sh '${KUBECTL} apply -f k8s/namespace.yaml'
            }
        }

        stage('Deploy') {
            steps {
                sh '${KUBECTL} apply -k k8s/ --namespace=${NAMESPACE}'
            }
        }

        stage('Update Image Tag') {
            steps {
                sh '''
                    ${KUBECTL} set image deployment/spring-app \
                        spring-app=${IMAGE_NAME}:${IMAGE_TAG} \
                        -n ${NAMESPACE}
                '''
            }
        }

        stage('Wait for Postgres') {
             steps {
                 sh '${KUBECTL} rollout status deployment/postgres --timeout=120s -n ${NAMESPACE}'
             }
        }

        stage('Wait for Rollout') {
            steps {
                sh '${KUBECTL} rollout status deployment/spring-app --timeout=120s -n ${NAMESPACE}'
            }
        }

        stage('Verify') {
            steps {
                sh '${KUBECTL} get pods -n ${NAMESPACE}'
                sh '${KUBECTL} get svc -n ${NAMESPACE}'
                sh '${KUBECTL} get ingress -n ${NAMESPACE}'
                sh '${KUBECTL} get networkpolicies -n ${NAMESPACE}'
            }
        }
    }

    post {
        success {
            echo "CD passed — build ${IMAGE_TAG} deployed to Minikube"
        }
        failure {
            sh '${KUBECTL} rollout undo deployment/spring-app -n ${NAMESPACE} || true'
            echo "CD failed — rolled back to previous version"
        }
    }
}